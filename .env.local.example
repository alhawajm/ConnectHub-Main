# ============================================================
# ConnectHub — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Anthropic (Claude AI) ---
# Get this from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ConnectHub
NEXT_PUBLIC_APP_ENV=development

# --- Demo / Showcase ---
# Keep disabled in production unless you intentionally want the demo guide visible.
NEXT_PUBLIC_ENABLE_DEMO_GUIDE=false
ENABLE_DEMO_SEED=false
# FORCE_DEMO_SEED=true

# --- Optional: Email (for notifications) ---
# RESEND_API_KEY=re_your-key-here

# --- OAuth Providers ---
# Enable Google / GitHub / Microsoft in Supabase Authentication > Providers.
# Add http://localhost:3000/auth/callback as an allowed redirect URL in local development.

# --- Payments (Tap) ---
# Tap is the current Bahrain-friendly checkout layer for cards, Apple Pay, and Benefit flows.
# Create keys in your Tap merchant dashboard before enabling live checkout.
TAP_SECRET_KEY=sk_live_or_test_here
# Optional: if you later expose Tap client-side widgets or signatures
# NEXT_PUBLIC_TAP_PUBLIC_KEY=pk_live_or_test_here
